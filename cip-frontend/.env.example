# Copy to .env.local and fill in. NEVER commit .env.local.
# The Next.js server proxies browser calls to the CIP API with this key,
# so the key is never exposed to the client.
CIP_API_BASE=http://localhost:4100
CIP_API_KEY=

# Preview mode: serve rich seeded demo data instead of calling the CIP API.
# Set to 1 to explore the full UI with no backend/Supabase/keys.
CIP_DEMO=0
