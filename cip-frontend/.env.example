# Copy to .env.local and fill in. NEVER commit .env.local.
# The Next.js server proxies browser calls to the CIP API with this key,
# so the key is never exposed to the client.
CIP_API_BASE=http://localhost:4100
CIP_API_KEY=

# Preview mode: serve rich seeded demo data instead of calling the CIP API.
# Set to 1 to explore the full UI with no backend/Supabase/keys.
CIP_DEMO=0

# Supabase (via @supabase/ssr). The publishable key is client-safe (like the
# anon key) and IS exposed to the browser — never put the service_role key here.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
