# wealth-agent configuration. Copy to `.env` and fill in.
# The agent NEVER needs bank, card, brokerage, or wallet credentials.
# It operates on a virtual ledger and proposes actions; YOU execute real money.

# --- Seed capital (the only "money" the agent knows about) ---
SEED_CAPITAL_USD=100

# --- Claude (optional). Without a key, the scout uses its built-in vetted catalog. ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Money boundary (hard guardrail) ---
# advise_only        : agent proposes, you execute every real transaction (default, honors "don't touch my bank account")
# prepaid_wallet     : you fund a separate prepaid instrument; agent still proposes, you approve per action
# scoped_autonomy    : reserved; requires explicit per-category limits you set later
MONEY_MODE=advise_only

# --- Moltbook integrity client (https://www.moltbook.com) ---
# dry_run=true means NOTHING is ever posted; actions are only assessed + logged.
MOLTBOOK_DRY_RUN=true
MOLTBOOK_AGENT_HANDLE=
# Disclosure string appended to every post/comment so readers know this is an AI agent.
MOLTBOOK_DISCLOSURE=Posted by an AI agent on behalf of its human operator.
MOLTBOOK_MIN_SECONDS_BETWEEN_ACTIONS=45

# --- Local state ---
STATE_DIR=data/state
