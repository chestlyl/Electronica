# ──────────────────────────────────────────────────────────────────────────
# Church Intelligence Platform — environment configuration
# Copy to `.env` and fill in. Never commit your real .env.
# ──────────────────────────────────────────────────────────────────────────

# --- Supabase (source of truth) ---------------------------------------------
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# Service-role key (server-side only — has full DB access, keep secret).
SUPABASE_SERVICE_ROLE_KEY=
# Anon key (only needed if you wire the dashboard to client-side auth).
SUPABASE_ANON_KEY=

# --- Claude / Anthropic -----------------------------------------------------
ANTHROPIC_API_KEY=
# Model used for extraction/scoring. Opus for hardest reasoning; Sonnet is a
# strong cheaper default for high-volume enrichment.
CLAUDE_MODEL=claude-sonnet-4-6
# Optional override for self-hosted/proxy gateways.
# ANTHROPIC_BASE_URL=

# Approx USD pricing per 1M tokens for the model above (for cost_estimate).
CLAUDE_INPUT_COST_PER_MTOK=3
CLAUDE_OUTPUT_COST_PER_MTOK=15
# Write each raw Claude response to data/debug/last-claude-response.txt (debugging).
CLAUDE_DEBUG=false

# --- Research / crawling ----------------------------------------------------
# Identifies the crawler politely in requests.
CRAWLER_USER_AGENT=ChurchIntelBot/1.0 (+https://millionmemberchurch.org/bot)
# Polite delay between requests to the same host (ms).
CRAWL_DELAY_MS=2000
# Max internal pages to crawl per church website.
MAX_PAGES_PER_SITE=10
# Per-page navigation timeout (ms).
PAGE_TIMEOUT_MS=20000
# Run the browser headless (true in CI/servers).
HEADLESS=true
# Honor robots.txt (strongly recommended: true).
RESPECT_ROBOTS=true
# Force the plain-HTTP fetch crawler even if Chromium is installed
# (useful in locked-down/serverless environments with no browser).
FORCE_FETCH_FALLBACK=false
# Max pages for the fetch fallback crawler.
FETCH_MAX_PAGES=5
# Sample church URL the `doctor` command tries to fetch (egress test).
DOCTOR_SAMPLE_URL=https://www.life.church

# --- Auto-update / confidence thresholds ------------------------------------
# Confidence >= this updates the church record directly.
AUTO_UPDATE_THRESHOLD=85
# Confidence in [REVIEW_THRESHOLD, AUTO_UPDATE_THRESHOLD) -> review queue.
REVIEW_THRESHOLD=60
# Confidence below REVIEW_THRESHOLD -> evidence saved only, field untouched.

# --- Search providers (optional, recommended) -------------------------------
# The reported-attendance lookup (Outreach 100 / Hartford) and secondary
# enrichment depend on web search. The default HTML scrapers return nothing in
# many hosted environments — set ONE API key below to get a reliable backend.
# It is slotted ahead of the scrapers; absent, the scrapers remain the fallback.
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=

# --- Area prospecting -------------------------------------------------------
# Google Places key for the prospect-area / discovery enumeration.
GOOGLE_PLACES_API_KEY=
# Max churches fully dossiered per area run (cost bound).
PROSPECT_MAX_DOSSIERS=25

# --- Dashboard --------------------------------------------------------------
DASHBOARD_PORT=4000

# --- CIP API (Base44 integration) -------------------------------------------
# Shared bearer token Base44 must present: `Authorization: Bearer <CIP_API_KEY>`.
# The backend owns every other secret (Anthropic, Supabase, Places); Base44 only
# ever holds this token. Requests without it are rejected with 401.
CIP_API_KEY=
# Port the CIP API listens on (`npm run api`).
CIP_API_PORT=4100

# --- Base44 front-end app (publish target) ----------------------------------
# The agent PUBLISHES dossier results into the Base44 app's entities
# (`publish-base44` command). Keys come from the Base44 app's API reference.
BASE44_APP_ID=
BASE44_API_KEY=
BASE44_BASE_URL=https://church-intel-flow.base44.app/api
